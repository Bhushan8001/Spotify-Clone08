# Local development port (Render sets PORT automatically)
PORT=3000

# Frontend origin for CORS
CLIENT_ORIGIN=http://localhost:4200

# Render uses Environment variables from its dashboard, not this example file.
# Replace with real Atlas values only (never placeholders).
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/spotifyDB?retryWrites=true&w=majority

# Optional: retry delay for Mongo reconnect attempts
MONGO_RETRY_DELAY_MS=5000
