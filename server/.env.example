# Local development port (Render sets PORT automatically)
PORT=3000

# Frontend origin for CORS
CLIENT_ORIGIN=http://localhost:4200

# Use real values (no angle brackets). URL-encode special characters in password.
MONGO_URI=mongodb+srv://yourUser:yourPassword@cluster0.xxxxx.mongodb.net/spotifyDB?retryWrites=true&w=majority

# Optional: retry delay for Mongo reconnect attempts
MONGO_RETRY_DELAY_MS=5000
